# prefetch_models.sh generates the real `.env.narval` next to this file —
# that one is gitignored (absolute paths specific to your allocation).
# This is just a reference for what it contains.

export PROJECT_REPO="/project/<your_alloc>/road-barbados-htr"
export SCRATCH_REPO="/scratch/<you>/road-barbados-htr"
export MODEL_CACHE="/project/<your_alloc>/road-barbados-htr/model_cache"
export HF_HOME="$MODEL_CACHE/hf"
export TRANSFORMERS_CACHE="$HF_HOME"
export HF_HUB_OFFLINE=1
export XDG_DATA_HOME="$MODEL_CACHE/xdg_data"
export QWEN_MODEL_ID="Qwen/Qwen2.5-VL-7B-Instruct"
export CATMUS_MODEL_PATH="$MODEL_CACHE/kraken/catmus_pretrained.mlmodel"

# Raw competition images — large, re-derivable from the Zindi download
data/images/

# Experiment checkpoints and other large run artifacts
experiments/*/checkpoints/

# Model weights of any kind
*.pt
*.pth
*.safetensors
*.bin
*.onnx
*.ckpt

# Virtual environments
.venv-kraken/
.venv-vlm/
.venv/
venv/

# Narval: generated at prefetch time, contains allocation-specific absolute
# paths (see runners/narval/.env.narval.example for the template)
runners/narval/.env.narval
runners/narval/*.out

# Colab / rclone: never commit the OAuth token config
rclone.conf

# Python
__pycache__/
*.pyc
.ipynb_checkpoints/
.pytest_cache/

# Scratch run logs / intermediate prediction files, not the final artifacts
.runlogs/

# OS / editor cruft
.DS_Store
Thumbs.db
.vscode/
